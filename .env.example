# Database Configuration
DATABASE_URL=postgres://mcp_user:mcp_password@localhost:5432/mcp_octo_enigma?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=mcp_user
DB_PASSWORD=mcp_password
DB_NAME=mcp_octo_enigma
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json

# AI Provider API Keys
GOOGLE_AI_API_KEY=your-google-ai-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
VERTEX_AI_PROJECT_ID=your-vertex-ai-project-id

# MCP Server Configuration
MCP_SERVER_PORT=8080
MCP_CLIENT_TIMEOUT=30s
LOG_LEVEL=info

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Configuration
API_SECRET_KEY=your-secret-key-for-jwt-change-this-in-production
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true

# Development Configuration
DEBUG=true
HOT_RELOAD=true